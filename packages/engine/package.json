{
  "name": "@arcforge/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/compiler.js",
      "types": "./dist/compiler.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@arcforge/schemas": "workspace:*",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.166.1",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/three": "^0.166.0",
    "vitest": "^2.0.5"
  }
}
