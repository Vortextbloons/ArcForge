{
  "name": "@arcforge/exporter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arcforge-export": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "export": "node ./dist/cli.js"
  },
  "dependencies": {
    "@arcforge/schemas": "workspace:*",
    "@arcforge/engine": "workspace:*",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
