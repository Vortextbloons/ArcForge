{
  "name": "arcforge",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop game editor and runtime framework for building shippable Three.js games",
  "scripts": {
    "dev": "turbo dev",
    "dev:tauri": "pnpm --filter @arcforge/editor-tauri tauri dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "export:web": "node ./packages/exporter/dist/cli.js web",
    "export:three": "node ./packages/exporter/dist/cli.js three",
    "mcp": "node ./packages/mcp-server/dist/cli.js"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "prettier": "latest",
    "eslint": "latest",
    "@types/node": "latest"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=18"
  }
}
